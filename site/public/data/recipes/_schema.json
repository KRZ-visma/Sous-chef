{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sous-chef recipe",
  "type": "object",
  "required": ["id", "name", "days", "ingredients"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case slug; must match the filename without .json"
    },
    "name": { "type": "string", "minLength": 1 },
    "days": {
      "type": "number",
      "minimum": 1,
      "description": "How many days this recipe covers (often 1 or 2)"
    },
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string", "minLength": 1 },
          "amount": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    }
  }
}
